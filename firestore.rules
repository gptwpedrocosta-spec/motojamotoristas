rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to validate document ID size and structure
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Drivers collection
    match /drivers/{driverId} {
      allow read: if true; // Allow reading profiles for lookups
      allow create, update: if isSignedIn() && request.auth.uid == driverId && isValidId(driverId);
      allow delete: if false;

      // Location subcollection support
      match /location/{locId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && request.auth.uid == driverId;
      }
    }

    // Motoristas collection (from Admin system)
    match /motoristas/{motoristaId} {
      allow read, write: if true;
    }

    // Users collection (from Admin system)
    match /users/{userId} {
      allow read, write: if true;
    }

    // Motoristas online collection
    match /motoristas_online/{driverId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == driverId && isValidId(driverId);
      allow delete: if isSignedIn() && request.auth.uid == driverId;
    }

    // Wallets collection
    match /wallets/{driverId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == driverId && isValidId(driverId);
      allow delete: if false;
    }

    // carteira_motorista collection
    match /carteira_motorista/{driverId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == driverId && isValidId(driverId);
      allow delete: if false;
    }

    // Rides collection
    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(rideId);
      allow update: if isSignedIn() && (
        // Allow anyone (simulator or driver) to update statuses
        // In real apps, we would restrict driver modifications to their own rides,
        // but since we include passenger simulators inside the same driver interface, 
        // we'll allow driver updates for assigned or new rides.
        resource.data.status == 'pending' || 
        resource.data.driverId == request.auth.uid ||
        request.resource.data.driverId == request.auth.uid
      );
      allow delete: if false;
    }

    // Chats collection
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(chatId);
      allow update, delete: if false;
    }
  }
}
